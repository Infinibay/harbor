{
  "name": "@infinibay/harbor",
  "version": "0.3.1",
  "description": "Harbor — living UI component library for Infinibay.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Infinibay/harbor.git"
  },
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE*"
  ],
  "main": "./dist/components/index.js",
  "module": "./dist/components/index.js",
  "types": "./dist/components/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/components/index.d.ts",
      "source": "./src/components/index.ts",
      "import": "./dist/components/index.js"
    },
