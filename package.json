    "./tokens.css": "./dist/tokens.css",
    "./index.css": "./dist/index.css",
    "./tailwind-preset": {
      "source": "./tailwind.config.js",
      "import": "./dist/tailwind.config.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:package": "vite build --config vite.package.config.ts && tsc -p tsconfig.build.json && cp src/index.css dist/index.css && cp src/tokens.css dist/tokens.css && cp tailwind.config.js dist/tailwind.config.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "vitest run -t 'a11y'",
    "test:ssr-package": "node scripts/ssr-package-smoke.mjs",
    "test:package": "npm run build:package && npm run test:ssr-package && vitest run src/components/package-exports.test.ts src/components/package-consumer.test.tsx",
    "test:quality": "vitest run src/components/quality-gates.test.tsx src/components/package-exports.test.ts src/components/package-consumer.test.tsx src/components/layout/ProductShell.test.tsx src/components/data/DataWorkspace.test.tsx src/components/dev/AgentWorkflow.test.tsx src/lib/a11y/a11y.test.tsx src/lib/theme/validateTheme.test.ts src/lib/form/pragmatic.test.tsx"
  },
  "peerDependencies": {
    "framer-motion": ">=11",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__traverse": "^7.28.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "framer-motion": "^12.38.0",
    "globals": "^17.4.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.5"
  }
