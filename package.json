    },
    "./navigation": {
      "types": "./dist/components/navigation/index.d.ts",
      "source": "./src/components/navigation/index.ts",
      "import": "./dist/components/navigation/index.js"
    },
    "./layout": {
      "types": "./dist/components/layout/index.d.ts",
      "source": "./src/components/layout/index.ts",
      "import": "./dist/components/layout/index.js"
    },
    "./chat": {
      "types": "./dist/components/chat/index.d.ts",
      "source": "./src/components/chat/index.ts",
